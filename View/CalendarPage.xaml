<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PigulaSchedule.View.CalendarPage"
             xmlns:resources="clr-namespace:PigulaSchedule.Resources"
             xmlns:controls="clr-namespace:PigulaSchedule.Calendar"
             xmlns:local="clr-namespace:PigulaSchedule.Model"
             Title="Kalendarz">

    <Grid RowDefinitions="*" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <controls:CalendarView
                    HighlightedDatesColor1="{Binding DatesColor1}"
                    HighlightedDatesColor2="{Binding DatesColor2}"
                    Color1="#378ADD"
                    Color2="#D4537E"/>


            </VerticalStackLayout>
        </ScrollView>


    </Grid>
</ContentPage>